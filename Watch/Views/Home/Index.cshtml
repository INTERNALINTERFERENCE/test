@{
    Layout = null;
}

<!doctype html>
<html>
<head>
    <meta charset="utf-8" />
    <link rel="stylesheet" href="~/css/style.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/normalize/5.0.0/normalize.min.css">
</head>
<body>
    <header class="showcase">
        <div class="showcase-top">
            @*<img src="" alt="" />
                <a href="#">Sign In</a>*@
        </div>
        <div class="showcase-content">
            <h1>See what's next</h1>
            <p>Watch movies together</p>

            <div class="demo-btns">
                <div class="info">
                    <div class="buttons">
                        <a href="#" data-modal="#modal" class="modal__trigger">Join Room</a>
                        <a href="#" data-modal="#modal2" class="modal__trigger">Create Room</a>
                    </div>
                </div>
            </div>

        </div>
    </header>

    <!-- Modal 1-->
    <div id="modal" class="modal modal__bg" role="dialog" aria-hidden="true">
        <div class="modal__dialog">
            <div class="modal__content">

                @* TODO: FILL THE FORM *@
                <form asp-controller="Home" asp-action="Index" method="post">
                    <div class="demo-btns">
                        <div class="info">
                            <div class="buttons">
                                <p><input type="text" name="userName" placeholder="Name:" size="18" /></p>
                                <p><input type="text" name="roomCode" placeholder="Code of the room:" size="18" /></p>
                                <input type="submit" class="modal__trigger2" value="Join Room" />
                            </div>
                        </div>
                    </div>
                </form>
                <!-- modal close button -->
                <a href="" class="modal__close demo-close">
                    <svg class="" viewBox="0 0 24 24"><path d="M19 6.41l-1.41-1.41-5.59 5.59-5.59-5.59-1.41 1.41 5.59 5.59-5.59 5.59 1.41 1.41 5.59-5.59 5.59 5.59 1.41-1.41-5.59-5.59z" /><path d="M0 0h24v24h-24z" fill="none" /></svg>
                </a>
            </div>
        </div>
    </div>


    <div id="modal2" class="modal modal__bg" role="dialog" aria-hidden="true">
        <div class="modal__dialog">
            <div class="modal__content">

                @* TODO: FILL THE FORM *@
                <form asp-controller="Home" asp-action="Index">
                    <div class="demo-btns">
                        <div class="info">
                            <div class="buttons">
                                <p><input type="text" name="userName" placeholder="Name:" size="18" /></p>
                                <input type="submit" class="modal__trigger2" value="Join Room" />
                            </div>
                        </div>
                    </div>
                </form>

                <!-- modal close button -->
                <a href="" class="modal__close demo-close">
                    <svg class="" viewBox="0 0 24 24"><path d="M19 6.41l-1.41-1.41-5.59 5.59-5.59-5.59-1.41 1.41 5.59 5.59-5.59 5.59 1.41 1.41 5.59-5.59 5.59 5.59 1.41-1.41-5.59-5.59z" /><path d="M0 0h24v24h-24z" fill="none" /></svg>
                </a>
            </div>
        </div>
    </div>

    <script src="~/js/index.js"></script>
</body>
</html>
